{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/download",
      "methods": ["POST"],
      "dest": "server.js"
    },
    {
      "src": "/progress",
      "methods": ["GET"],
      "dest": "server.js"
    },
    {
      "src": "/(.*)",
      "dest": "public/$1"
    }
  ]
}
